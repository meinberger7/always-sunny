{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DashboardMetadata",
  "type": "object",
  "properties": {
    "balancing_authorities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ba_code", "ba_name", "interconnection", "lat", "lon"],
        "properties": {
          "ba_code": {"type": "string"},
          "ba_name": {"type": "string"},
          "interconnection": {"type": "string"},
          "lat": {"type": "number"},
          "lon": {"type": "number"}
        }
      }
    },
    "scenarios": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["scenario_id", "buildout_target_pct_of_annual_demand", "transmission_scope"],
        "properties": {
          "scenario_id": {"type": "string"},
          "buildout_target_pct_of_annual_demand": {"type": "number"},
          "transmission_scope": {"type": "string"}
        }
      }
    },
    "app_config": {"type": "object"}
  }
}
